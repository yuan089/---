{
    "format_version": "1.21.0",
    "minecraft:block": {
        "description": {
            "identifier": "bangdream:keluji",
            "menu_category": { "category": "items", "group": "itemGroup.name.item" },
            "states": {
                "bangdream:active": [false, true],
                "bangdream:direction": [0, 1, 2, 3] 
            }
        },
        "components": {
            "minecraft:display_name": "tile.bangdream:keluji.name",
            "minecraft:destructible_by_mining": { "seconds_to_destroy": 1.5 },
            "minecraft:geometry": { "identifier": "geometry.bangdream_jukebox" },
            "minecraft:material_instances": {
                "*": { "texture": "keluji_side", "render_method": "opaque" },
                "up": { "texture": "keluji_top", "render_method": "opaque" },
                "north": { "texture": "keluji_front_idle", "render_method": "opaque" }
            },
            "minecraft:custom_components": ["bangdream:keluji_logic"]
        },
        "permutations": [
            { "condition": "q.block_state('bangdream:direction') == 0", "components": { "minecraft:material_instances": { "north": { "texture": "keluji_front_idle" }, "up": { "texture": "keluji_top" }, "*": { "texture": "keluji_side" } } } },
            { "condition": "q.block_state('bangdream:direction') == 0 && q.block_state('bangdream:active') == true", "components": { "minecraft:material_instances": { "north": { "texture": "keluji_front_active" }, "up": { "texture": "keluji_top" }, "*": { "texture": "keluji_side" } } } },
            { "condition": "q.block_state('bangdream:direction') == 1", "components": { "minecraft:material_instances": { "south": { "texture": "keluji_front_idle" }, "up": { "texture": "keluji_top" }, "*": { "texture": "keluji_side" } } } },
            { "condition": "q.block_state('bangdream:direction') == 1 && q.block_state('bangdream:active') == true", "components": { "minecraft:material_instances": { "south": { "texture": "keluji_front_active" }, "up": { "texture": "keluji_top" }, "*": { "texture": "keluji_side" } } } },
            { "condition": "q.block_state('bangdream:direction') == 2", "components": { "minecraft:material_instances": { "west": { "texture": "keluji_front_idle" }, "up": { "texture": "keluji_top" }, "*": { "texture": "keluji_side" } } } },
            { "condition": "q.block_state('bangdream:direction') == 2 && q.block_state('bangdream:active') == true", "components": { "minecraft:material_instances": { "west": { "texture": "keluji_front_active" }, "up": { "texture": "keluji_top" }, "*": { "texture": "keluji_side" } } } },
            { "condition": "q.block_state('bangdream:direction') == 3", "components": { "minecraft:material_instances": { "east": { "texture": "keluji_front_idle" }, "up": { "texture": "keluji_top" }, "*": { "texture": "keluji_side" } } } },
            { "condition": "q.block_state('bangdream:direction') == 3 && q.block_state('bangdream:active') == true", "components": { "minecraft:material_instances": { "east": { "texture": "keluji_front_active" }, "up": { "texture": "keluji_top" }, "*": { "texture": "keluji_side" } } } }
        ]
    }
}